<section class="middle-page">
  <div class="product-page">

    <!-- ==================== FILTRES ==================== -->
    <aside class="filters">

      <h2 class="filters-title">Filtres</h2>

      <details class="filter-dropdown" open>
        <summary><span>% Promo</span></summary>
        <div class="dropdown-content">
          <label><input type="checkbox"> -10%</label>
          <label><input type="checkbox"> -20%</label>
          <label><input type="checkbox"> -50%</label>
        </div>
      </details>

      <details class="filter-dropdown">
        <summary><span>Catégorie</span></summary>
        <div class="dropdown-content">
          <label><input type="checkbox"> Fruits</label>
          <label><input type="checkbox"> Légumes</label>
          <label><input type="checkbox"> Viandes</label>
        </div>
      </details>

      <details class="filter-dropdown">
        <summary><span>Marque</span></summary>
        <div class="dropdown-content">
          <label><input type="checkbox"> Carrefour</label>
          <label><input type="checkbox"> Leclerc</label>
          <label><input type="checkbox"> Bio Village</label>
        </div>
      </details>

      <details class="filter-dropdown">
        <summary><span>Allergènes</span></summary>
        <div class="dropdown-content">
          <label><input type="checkbox"> Sans gluten</label>
          <label><input type="checkbox"> Sans lactose</label>
          <label><input type="checkbox"> Sans arachide</label>
        </div>
      </details>

      <details class="filter-dropdown">
        <summary><span>Favoris</span></summary>
        <div class="dropdown-content">
          <label><input type="checkbox"> Produits suivis</label>
        </div>
      </details>

    </aside>

